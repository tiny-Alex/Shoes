<Page x:Class="shoes.pages.AddEdirProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:shoes.pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="AddEdirProductsPage" Background="#FFFFFF">

    <Grid>

        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Артикул</TextBlock>
                    <TextBox  Text="{Binding Article}"></TextBox>
                </StackPanel>

                
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Наименование</TextBlock>
                    <TextBox Text="{Binding Name}"></TextBox>
                </StackPanel> 
                
                
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Категория</TextBlock>
                    <ComboBox Name="categoryTb" Text="{Binding Category.Name}"></ComboBox>
                </StackPanel>


                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Прайс</TextBlock>
                    <TextBox Text="{Binding Price}"></TextBox>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Поставщик</TextBlock>
                    <TextBox Text="{Binding Supplier.Name}"></TextBox>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Производитель</TextBlock>
                    <TextBox Text="{Binding Manufacturer.Name}"></TextBox>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Единица измерения</TextBlock>
                    <ComboBox x:Name="EzCB" SelectedItem="{Binding Unit.Name }"/>
                </StackPanel>


                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Скидка</TextBlock>
                    <TextBox Text="{Binding Discount}"></TextBox>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Количество</TextBlock>
                    <TextBox Text="{Binding Count}"></TextBox>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Описание товара</TextBlock>
                    <TextBox Text="{Binding Discription}"></TextBox>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock>Фотография</TextBlock>
                    <TextBox Text="{Binding PhotoPath}"></TextBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="SaveBtn" Click="SaveBtn_Click">Сохранить</Button>
                    <Button x:Name="CancelBtn" Click="CancelBtn_Click">Отмена</Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
