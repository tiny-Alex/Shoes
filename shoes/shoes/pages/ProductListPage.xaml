<Page x:Class="shoes.pages.ProductList"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:shoes.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductList">


    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
            Background="#00FA9A" 
            CornerRadius="10" 
            Padding="15"
            Margin="20,20,20,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Поиск:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox x:Name="SearchBox" 
                     Grid.Column="1"
                     FontSize="14" 
                     Padding="10" TextChanged="SearchBox_TextChanged_1"/>

                <ComboBox x:Name="FilterCombo" 
                      Grid.Column="2" 
                      Width="200"
                      Height="40"
                      Margin="10,0"
                      FontSize="14"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id" SelectionChanged="FilterCombo_SelectionChanged_1"/>

                <Button x:Name="ClearFilterBtn" 
                    Grid.Column="3"
                    Content="Сбросить"
                    Width="100"
                    Height="40"
                    Background="#7FFF00"
                    FontSize="14"
                    Cursor="Hand" Click="ClearFilterBtn_Click_1"/>
            </Grid>
        </Border>

        <ListView x:Name="ProductLst" 
              Grid.Row="1"
              Margin="20,0,20,20"
              Background="White">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="2" Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border BorderBrush="Black" Margin="5" Grid.Column="0" BorderThickness="2">
                                <Image Width="250" Source="{Binding FullPhotoPath}" />
                            </Border>

                            <Border BorderBrush="Black" Margin="5" BorderThickness="2" Grid.Column="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="Bold" Text="{Binding Category.Name}"/>
                                        <TextBlock FontWeight="Bold" Text="{Binding Name}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Описание товара</TextBlock>
                                        <TextBlock Text="{Binding Description}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Производитель</TextBlock>
                                        <TextBlock Text="{Binding Supplier.Name}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Поставщик</TextBlock>
                                        <TextBlock Text="{Binding Manufacturer.Name}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Цена</TextBlock>
                                        <TextBlock Text="{Binding Price}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Единица измерения</TextBlock>
                                        <TextBlock Text="{Binding Unit.Name}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock>Количество на складе</TextBlock>
                                        <TextBlock Text="{Binding Count}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="Black" BorderThickness="2" Margin="5" Width="200" Grid.Column="2">
                                <TextBlock Text="{Binding Discount}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Orientation="Horizontal" 
                Grid.Row="2" 
                HorizontalAlignment="Right" 
                Margin="20,0,20,20">
            <Button x:Name="AddBtn" 
                Content="Добавить" 
                Width="120" 
                Height="40"
                Margin="5"
                Background="#7FFF00"
                FontSize="14"
                Cursor="Hand" Click="AddBtn_Click"/>
            
            <Button x:Name="EditBtn" 
                Content="Изменить" 
                Width="120" 
                Height="40"
                Margin="5"
                Background="#7FFF00"
                FontSize="14"
                Cursor="Hand" Click="EditBtn_Click"/>
            
            <Button x:Name="DeleteBtn" 
                Content="Удалить" 
                Width="120" 
                Height="40"
                Margin="5"
                Background="#7FFF00"
                FontSize="14"
                Cursor="Hand" Click="DeleteBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
