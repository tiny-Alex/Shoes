<Page x:Class="shoes.pages.AuthrizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:shoes.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthrizationPage">


    <Grid>
        <StackPanel HorizontalAlignment="Center" 
                 VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                <TextBlock> Логин</TextBlock>
                <TextBox x:Name="LoginTb"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                <TextBlock> Пароль</TextBlock>
                <PasswordBox x:Name="PassTb"/>
            </StackPanel>

 
                <Button x:Name="LoginBtn" Click="LoginBtn_Click">Вход</Button>
            <Button x:Name="GuestBtn" HorizontalAlignment="Center" FontStyle="Oblique" Content="Режим гостя " Click="GuestBtn_Click"/>

        </StackPanel>
    </Grid>
</Page>
